{
  "name": "daomind-modulux",
  "version": "2.0.0",
  "private": true,
  "description": "DaoMind & Modulux — 现代化系统框架与模块化组件库",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @daomind/nothing build && pnpm -r build && pnpm build:app",
    "build:app": "pnpx vite build",
    "dev": "pnpx vite",
    "test": "jest",
    "lint": "eslint . --ignore-pattern 'coverage/**'",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"supabase/functions/**/*.ts\" \"docs/site/**/*.md\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.2.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  }
}
